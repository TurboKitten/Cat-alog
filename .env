# ==============================
# Variables para Docker Compose
# Copia este archivo como .env y ajusta los valores
# ==============================

# MySQL container
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=cat_alog
MYSQL_HOST_PORT=3307
MYSQL_CONTAINER_PORT=3306

# App container
APP_HOST_PORT=8080

# Spring Boot app (en Docker)
DB_URL_DOCKER=jdbc:mysql://mysql:3306/cat_alog?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=root

# Seguridad JWT (minimo 32 caracteres)
JWT_SECRET=cat_alog-super-secret-key-i-love-cats

# API externa
CATAPI_BASE_URL=https://api.thecatapi.com/v1
